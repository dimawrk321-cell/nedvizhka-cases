---
/**
 * RadioGroup — доступная группа радиокнопок со стилизованными состояниями.
 * Используется для выбора способа связи в форме заявки.
 */
export interface RadioOption {
  value: string;
  label: string;
}

interface Props {
  name: string;
  legend: string;
  options: RadioOption[];
  /** Предвыбранное значение */
  value?: string;
  required?: boolean;
}

const { name, legend, options, value, required = false } = Astro.props;
---

<fieldset class="flex flex-col gap-2">
  <legend class="mb-1 text-sm font-medium text-ink [.surface-dark_&]:text-paper">{legend}</legend>
  <div class="flex flex-wrap gap-2">
    {
      options.map((opt) => (
        <label class="group flex min-h-[44px] cursor-pointer items-center gap-2.5 rounded-card border border-stone bg-paper px-4 py-2 text-sm text-ink transition-colors has-[:checked]:border-brass has-[:checked]:bg-brass/10 has-[:focus-visible]:outline has-[:focus-visible]:outline-2 has-[:focus-visible]:outline-offset-2 has-[:focus-visible]:outline-brass [.surface-dark_&]:border-stone/30 [.surface-dark_&]:bg-pine [.surface-dark_&]:text-paper [.surface-dark_&]:has-[:checked]:border-brass-light">
          <input
            type="radio"
            name={name}
            value={opt.value}
            required={required}
            checked={value === opt.value}
            class="peer sr-only"
          />
          <span class="grid h-4 w-4 shrink-0 place-items-center rounded-full border border-stone transition-colors peer-checked:border-brass peer-checked:[&>span]:scale-100 [.surface-dark_&]:border-stone/40 [.surface-dark_&]:peer-checked:border-brass-light">
            <span class="h-2 w-2 scale-0 rounded-full bg-brass transition-transform [.surface-dark_&]:bg-brass-light" />
          </span>
          {opt.label}
        </label>
      ))
    }
  </div>
</fieldset>
