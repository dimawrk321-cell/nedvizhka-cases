---
/**
 * PhoneField — телефон с маской +7 (___) ___-__-__ на чистом JS
 * и нативной валидацией через pattern. Опирается на Input.
 */
import Input from './Input.astro';

interface Props {
  name?: string;
  label?: string;
  required?: boolean;
  id?: string;
}

const { name = 'phone', label = 'Телефон', required = true, id = 'phone' } = Astro.props;
---

<Input
  id={id}
  name={name}
  label={label}
  type="tel"
  required={required}
  placeholder="+7 (___) ___-__-__"
  autocomplete="tel"
  inputmode="tel"
  pattern="\+7 \(\d{3}\) \d{3}-\d{2}-\d{2}"
  maxlength={18}
/>

<script>
  function formatPhone(raw: string): string {
    let digits = raw.replace(/\D/g, '');
    if (digits.startsWith('8')) digits = '7' + digits.slice(1);
    if (!digits.startsWith('7')) digits = '7' + digits;
    digits = digits.slice(0, 11);
    const rest = digits.slice(1);
    let out = '+7';
    if (rest.length > 0) out += ' (' + rest.slice(0, 3);
    if (rest.length >= 3) out += ')';
    if (rest.length >= 3) out += ' ' + rest.slice(3, 6);
    if (rest.length >= 6) out += '-' + rest.slice(6, 8);
    if (rest.length >= 8) out += '-' + rest.slice(8, 10);
    return out;
  }

  document.querySelectorAll('input[type="tel"]').forEach((el) => {
    if (!(el instanceof HTMLInputElement)) return;
    el.addEventListener('input', () => {
      el.value = formatPhone(el.value);
    });
    el.addEventListener('focus', () => {
      if (!el.value) el.value = '+7 ';
    });
    el.addEventListener('blur', () => {
      if (el.value === '+7' || el.value === '+7 ') el.value = '';
    });
  });
</script>
