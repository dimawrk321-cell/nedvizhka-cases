---
/**
 * ListingCard — карточка объекта недвижимости для раздела «Актуальные объявления».
 * Данные — из listings.ts. Фото пока плейсхолдер (градиент pine→ink + иконка), заменяется
 * на реальное изображение одной строкой (см. TODO ниже). data-category на корне — для
 * JS-фильтра по категориям на странице. Ссылка «на карте» строит Яндекс.Карты по адресу
 * (координаты в код не вшиваем). Карточки равной высоты: h-full/flex-col + mt-auto у кнопки.
 */
import type { Listing } from '../data/listings';
import { listingCategories } from '../data/listings';
import { Building2, TrainFront, MapPin } from 'lucide-static';

interface Props {
  listing: Listing;
}
const { listing } = Astro.props;

const categoryTitle =
  listingCategories.find((c) => c.id === listing.category)?.title ?? listing.category;
// Яндекс сам находит объект по адресу — координаты не нужны
const mapHref = `https://yandex.ru/maps/?text=${encodeURIComponent(listing.address)}`;
---

<article
  data-category={listing.category}
  class="group flex h-full flex-col overflow-hidden rounded-lg border border-stone bg-paper transition duration-200 hover:-translate-y-1 hover:border-brass hover:shadow-md"
>
  {/* Фото объекта — плейсхолдер. TODO: заменить на реальное изображение (astro:assets <Picture>) */}
  <div class="relative aspect-[3/2] overflow-hidden bg-[linear-gradient(160deg,var(--color-pine),var(--color-ink))]">
    <div class="absolute inset-0 grid place-items-center text-paper opacity-20 [&>svg]:h-16 [&>svg]:w-16">
      <span set:html={Building2} aria-hidden="true" />
    </div>
  </div>

  <div class="flex flex-1 flex-col gap-3 p-5">
    <p class="eyebrow text-brass">{categoryTitle}</p>

    <h3 class="text-lg font-semibold text-ink">{listing.title}</h3>

    <p class="stat-num text-[26px] leading-none text-brass">{listing.price}</p>

    {/* Площадь и метро (если есть) */}
    <p class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-muted">
      <span>{listing.area}</span>
      {
        listing.metro && (
          <span class="inline-flex items-center gap-1 [&>svg]:h-4 [&>svg]:w-4">
            <span set:html={TrainFront} aria-hidden="true" />
            {listing.metro}
          </span>
        )
      }
    </p>

    {/* Ключевые характеристики — компактными чипами */}
    <ul class="flex flex-wrap gap-1.5">
      {
        listing.params.map((param) => (
          <li class="rounded-card border border-stone px-2 py-0.5 text-xs text-muted">{param}</li>
        ))
      }
    </ul>

    {/* Описание — обрезано до 3 строк, чтобы карточки были ровными */}
    <p class="line-clamp-3 text-sm text-muted">{listing.description}</p>

    {/* Кнопка «на карте» — прижата к низу карточки */}
    <a
      href={mapHref}
      target="_blank"
      rel="noopener"
      class="mt-auto inline-flex min-h-[44px] w-fit items-center gap-2 rounded-card border border-stone px-4 text-sm font-medium text-ink transition-colors hover:border-brass hover:text-brass [&>svg]:h-4 [&>svg]:w-4"
    >
      <span set:html={MapPin} aria-hidden="true" />Показать на карте
    </a>
  </div>
</article>
