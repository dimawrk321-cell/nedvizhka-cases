---
/**
 * Button — рендерится как <a> (если задан href) или <button>.
 * Варианты: primary (заливка brass) и ghost (бордер stone → brass на hover).
 * Внутри тёмных секций (.surface-dark) перекрашивается автоматически.
 * Стрелка lucide сдвигается вправо на hover.
 */
import { ArrowRight } from 'lucide-static';

interface Props {
  variant?: 'primary' | 'ghost';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  /** Показывать стрелку (по умолчанию — у primary) */
  arrow?: boolean;
  class?: string;
}

const {
  variant = 'primary',
  href,
  type = 'button',
  arrow,
  class: className = '',
} = Astro.props;

const showArrow = arrow ?? variant === 'primary';

const base =
  'group inline-flex min-h-[44px] items-center justify-center gap-2 rounded-lg px-6 py-3 text-center font-sans font-medium leading-none transition duration-200 select-none disabled:cursor-not-allowed disabled:opacity-60';

const styles: Record<'primary' | 'ghost', string> = {
  primary:
    'bg-brass text-ink hover:opacity-90 [.surface-dark_&]:bg-brass-light [.surface-dark_&]:text-ink',
  ghost:
    'border border-stone text-ink hover:border-brass [.surface-dark_&]:border-stone/30 [.surface-dark_&]:text-paper [.surface-dark_&]:hover:border-brass-light',
};

const cls = [base, styles[variant], className].filter(Boolean).join(' ');
const Tag = href ? 'a' : 'button';
---

<Tag class={cls} href={href} type={href ? undefined : type}>
  <slot />
  {
    showArrow && (
      <span
        class="inline-flex shrink-0 transition-transform duration-200 group-hover:translate-x-1 [&>svg]:h-[1.15em] [&>svg]:w-[1.15em]"
        set:html={ArrowRight}
        aria-hidden="true"
      />
    )
  }
</Tag>
