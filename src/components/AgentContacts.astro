---
/**
 * AgentContacts — блок «Контакты» в профиле агента.
 * Телефон: берём личный номер агента (phone), иначе откат на общий из site.ts.
 * Мессенджеры (Telegram/MAX из site.ts) показываем только когда showMessengers=true —
 * пока это основной контакт (Дарья); у Дмитрия сейчас только телефон (свои мессенджеры позже).
 * WhatsApp в контактах профиля не показываем. Иконки lucide как в футере; каждая ссылка —
 * chip с min-h-[44px] (touch-target ≥44px); мессенджеры открываются в новой вкладке (rel=noopener).
 */
import { site } from '../data/site';
import type { AgentPhone } from '../data/agents';
import { Phone, Send, MessageSquare } from 'lucide-static';

interface Props {
  /** Личный номер агента; null — используется общий из site.ts */
  phone?: AgentPhone | null;
  /** Показывать общие мессенджеры (Telegram/MAX из site.ts); по умолчанию — только телефон */
  showMessengers?: boolean;
}
const { phone, showMessengers = false } = Astro.props;

// Телефон — из личного номера агента, при отсутствии откат на общий site.ts
const phoneDisplay = phone?.display ?? site.phone;
const phoneHref = phone?.href ?? site.phoneHref;

const chip =
  'inline-flex min-h-[44px] items-center gap-2 rounded-card border border-stone px-4 text-ink transition-colors hover:border-brass hover:text-brass [&>svg]:h-5 [&>svg]:w-5';
---

<div class="flex flex-col gap-6 border-t border-stone pt-10">
  <div class="flex flex-col gap-2">
    <h2 class="text-2xl">Контакты</h2>
    <p class="text-muted">Свяжитесь со мной удобным способом:</p>
  </div>

  <ul class="flex flex-wrap gap-3">
    <li>
      <a href={phoneHref} class={chip}>
        <span set:html={Phone} aria-hidden="true" />{phoneDisplay}
      </a>
    </li>
    {
      showMessengers && (
        <>
          <li>
            <a href={site.telegramHref} target="_blank" rel="noopener" class={chip}>
              <span set:html={Send} aria-hidden="true" />Telegram {site.telegram}
            </a>
          </li>
          <li>
            <a href={site.maxLink} target="_blank" rel="noopener" class={chip} aria-label="MAX">
              <span set:html={MessageSquare} aria-hidden="true" />MAX
            </a>
          </li>
        </>
      )
    }
  </ul>
</div>
