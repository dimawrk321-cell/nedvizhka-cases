---
/**
 * AgentServices — блок «Услуги» в профиле агента. Карточки как в прежней секции
 * Services (бордер stone, hover brass, иконка в квадрате). Иконка выбирается по
 * ключу service.icon. У каждого агента свой набор услуг (см. agents.ts).
 */
import type { Service } from '../data/services';
import {
  Home,
  Search,
  ArrowLeftRight,
  Landmark,
  ShieldCheck,
  Trees,
  Building2,
  KeyRound,
} from 'lucide-static';

interface Props {
  services: Service[];
}
const { services } = Astro.props;

const iconMap: Record<string, string> = {
  home: Home,
  search: Search,
  swap: ArrowLeftRight,
  landmark: Landmark,
  shield: ShieldCheck,
  trees: Trees,
  building: Building2,
  key: KeyRound,
};
---

{
  services.length > 0 && (
    <div class="flex flex-col gap-6 border-t border-stone pt-10">
      <h2 class="text-2xl">Услуги</h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <article class="group flex flex-col gap-4 rounded-lg border border-stone bg-paper p-6 transition duration-200 hover:-translate-y-1 hover:border-brass hover:shadow-md">
            <span
              class="inline-flex h-12 w-12 items-center justify-center rounded-card border border-stone text-brass transition-colors group-hover:border-brass [&>svg]:h-6 [&>svg]:w-6"
              set:html={iconMap[service.icon] ?? Home}
              aria-hidden="true"
            />
            <h3 class="text-lg font-semibold text-ink">{service.title}</h3>
            <p class="text-muted">{service.result}</p>
          </article>
        ))}
      </div>
    </div>
  )
}
