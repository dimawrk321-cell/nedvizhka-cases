---
/* Базовый макет страницы. Подключает дизайн-систему и self-hosted шрифты. */
import '../styles/global.css';

// Self-hosted шрифты (fontsource) — регистрируют @font-face (font-display: swap уже внутри)
import '@fontsource/prata/400.css';
import '@fontsource-variable/onest/wght.css';

// Preload основных woff2-сабсетов (latin + cyrillic) обоих начертаний.
// ?url отдаёт хэшированный путь к ассету; Vite дедуплицирует его с url() из @font-face.
import prataLatin from '@fontsource/prata/files/prata-latin-400-normal.woff2?url';
import prataCyrillic from '@fontsource/prata/files/prata-cyrillic-400-normal.woff2?url';
import onestLatin from '@fontsource-variable/onest/files/onest-latin-wght-normal.woff2?url';
import onestCyrillic from '@fontsource-variable/onest/files/onest-cyrillic-wght-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
}

const {
  // TODO: задать реальные title/description на этапе наполнения контентом
  title = 'Плейсхолдер заголовка — частный риелтор, Москва',
  description = 'Плейсхолдер описания страницы. Заменить на реальный SEO-текст.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// base из astro.config (для путей к ассетам в публичной папке при деплое в подпапку)
const base = import.meta.env.BASE_URL;
const preloadFonts = [prataLatin, prataCyrillic, onestLatin, onestCyrillic];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} sizes="32x32" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {
      preloadFonts.map((href) => (
        <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />
      ))
    }

    {/* Высота фиксированной шапки — единый источник для Header и Hero (global.css не трогаем) */}
    <style is:global>
      :root {
        --header-h: 4.5rem;
      }
      /* Ровный вертикальный ритм: между двумя соседними одноцветными (светлыми) секциями
         без разделителя не дублируем отступ — схлопываем верхний паддинг второй секции.
         Тёмные «полосы» (Hero/Process/FinalCTA) не помечаются data-bg и сохраняют симметрию. */
      [data-bg='light'] + [data-bg='light'] {
        padding-top: 0;
      }
    </style>
  </head>
  <body>
    <!-- Skip-link: скрыт, появляется по фокусу с клавиатуры -->
    <a class="skip-link" href="#main">Перейти к содержанию</a>

    <slot />

    <script>
      // UTM-метки: на загрузке любой страницы сохраняем utm_* из query в sessionStorage,
      // чтобы прикрепить их к заявке при отправке формы.
      try {
        const params = new URLSearchParams(window.location.search);
        const keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'];
        const utm: Record<string, string> = {};
        let found = false;
        keys.forEach((key) => {
          const value = params.get(key);
          if (value) {
            utm[key] = value;
            found = true;
          }
        });
        if (found) sessionStorage.setItem('lead_utm', JSON.stringify(utm));
      } catch {
        /* sessionStorage недоступен — не критично */
      }
    </script>

    <script>
      // Ленивая загрузка анимаций + страховка видимости контента.
      // Скрытые состояния ставит только GSAP в рантайме; если модуль не сработал
      // (reduced-motion, ошибка, 404 чанка, таймаут) — принудительно показываем весь контент.
      const revealAll = () => {
        document.querySelectorAll('[data-reveal], [data-reveal-item]').forEach((el) => {
          if (el instanceof HTMLElement) {
            el.style.opacity = '1';
            el.style.transform = 'none';
            el.style.translate = 'none';
          }
        });
      };

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReduced) {
        revealAll();
      } else {
        let ready = false;
        // Если за 2.5с анимации не инициализировались — снимаем возможные скрытые состояния
        window.setTimeout(() => {
          if (!ready) revealAll();
        }, 2500);

        let started = false;
        const start = () => {
          if (started) return;
          started = true;
          window.removeEventListener('scroll', start);
          import('../scripts/animations.ts')
            .then((module) => module.initAnimations())
            .then(() => {
              ready = true;
            })
            .catch(() => {
              revealAll();
            });
        };
        window.addEventListener('scroll', start, { once: true, passive: true });
        window.setTimeout(start, 1800);
      }
    </script>
  </body>
</html>
