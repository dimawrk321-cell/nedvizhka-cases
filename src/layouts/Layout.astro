---
/* Базовый макет страницы. Подключает дизайн-систему и self-hosted шрифты. */
import '../styles/global.css';

// Self-hosted шрифты (fontsource) — регистрируют @font-face (font-display: swap уже внутри)
import '@fontsource/prata/400.css';
import '@fontsource-variable/onest/wght.css';

import ScrollTop from '../components/ScrollTop.astro';

// Preload основных woff2-сабсетов (latin + cyrillic) обоих начертаний.
// ?url отдаёт хэшированный путь к ассету; Vite дедуплицирует его с url() из @font-face.
import prataLatin from '@fontsource/prata/files/prata-latin-400-normal.woff2?url';
import prataCyrillic from '@fontsource/prata/files/prata-cyrillic-400-normal.woff2?url';
import onestLatin from '@fontsource-variable/onest/files/onest-latin-wght-normal.woff2?url';
import onestCyrillic from '@fontsource-variable/onest/files/onest-cyrillic-wght-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  /** Заголовок для соцсетей (og/twitter); по умолчанию — общий для сайта */
  ogTitle?: string;
  /** Описание для соцсетей; по умолчанию — общее для сайта */
  ogDescription?: string;
  /** Путь к OG-картинке от корня (напр. `${base}og/og-daria.jpg`); по умолчанию — логотип */
  ogImage?: string;
}

const {
  // TODO: задать реальные title/description на этапе наполнения контентом
  title = 'Плейсхолдер заголовка — частный риелтор, Москва',
  description = 'Плейсхолдер описания страницы. Заменить на реальный SEO-текст.',
  ogTitle,
  ogDescription,
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// base из astro.config (для путей к ассетам в публичной папке при деплое в подпапку)
const base = import.meta.env.BASE_URL;
const preloadFonts = [prataLatin, prataCyrillic, onestLatin, onestCyrillic];

// OG/Twitter превью. Дефолт для всего сайта — логотип компании; страница может передать свои
// ogTitle/ogDescription/ogImage. og:image и og:url — АБСОЛЮТНЫЕ URL (соцсети требуют полный
// адрес с доменом) — собираем из Astro.site (astro.config) + путь с base.
const ogTitleFinal = ogTitle ?? 'Первый город — агентство недвижимости в Москве';
const ogDescriptionFinal =
  ogDescription ??
  // TODO: уточнить формулировку описания сайта
  'Продажа, покупка и аренда недвижимости в Москве и области. Ипотека, страхование, сопровождение сделок';
const ogImageUrl = new URL(ogImage ?? `${base}og/og-default.png`, Astro.site).href;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} sizes="32x32" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {/* Open Graph / Twitter — превью при шеринге. og:image и og:url — абсолютные (1200×630) */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Первый город" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogTitleFinal} />
    <meta property="og:description" content={ogDescriptionFinal} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitleFinal} />
    <meta name="twitter:description" content={ogDescriptionFinal} />
    <meta name="twitter:image" content={ogImageUrl} />

    {
      preloadFonts.map((href) => (
        <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />
      ))
    }

    {/* Высота фиксированной шапки — единый источник для Header и Hero (global.css не трогаем) */}
    <style is:global>
      :root {
        --header-h: 4.5rem;
      }
      /* Ровный вертикальный ритм: между двумя соседними одноцветными (светлыми) секциями
         без разделителя не дублируем отступ — схлопываем верхний паддинг второй секции.
         Тёмные «полосы» (Hero/Process/FinalCTA) не помечаются data-bg и сохраняют симметрию. */
      [data-bg='light'] + [data-bg='light'] {
        padding-top: 0;
      }
    </style>

    {/* Гейт анимаций. Ставится СИНХРОННО до первой отрисовки — поэтому нет мигания.
        Класс появляется только при живом JS: если скрипт не выполнится, класса не
        будет и CSS-правила скрытия не применятся → контент останется видимым. */}
    <script is:inline>
      (function () {
        try {
          if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.documentElement.classList.add('js-ready');
          }
        } catch (e) {
          /* нет matchMedia — просто оставляем контент видимым */
        }
      })();
    </script>
  </head>
  <body>
    <!-- Skip-link: скрыт, появляется по фокусу с клавиатуры -->
    <a class="skip-link" href="#main">Перейти к содержанию</a>

    <slot />

    {/* Плавающая кнопка «наверх» — одна на все страницы */}
    <ScrollTop />

    <script>
      // UTM-метки: на загрузке любой страницы сохраняем utm_* из query в sessionStorage,
      // чтобы прикрепить их к заявке при отправке формы.
      try {
        const params = new URLSearchParams(window.location.search);
        const keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'];
        const utm: Record<string, string> = {};
        let found = false;
        keys.forEach((key) => {
          const value = params.get(key);
          if (value) {
            utm[key] = value;
            found = true;
          }
        });
        if (found) sessionStorage.setItem('lead_utm', JSON.stringify(utm));
      } catch {
        /* sessionStorage недоступен — не критично */
      }
    </script>

    <script>
      // Анимации появления: нативный IntersectionObserver, без сторонних библиотек.
      // Запускаем сразу — модуль лёгкий (~2 КБ), ждать нечего.
      // Если импорт по любой причине не отработает, класс js-ready снимается и
      // контент остаётся видимым (см. фолбэк ниже и failSafe внутри модуля).
      import('../scripts/animations')
        .then((module) => module.initAnimations())
        .catch(() => {
          document.documentElement.classList.remove('js-ready');
        });
    </script>
  </body>
</html>
