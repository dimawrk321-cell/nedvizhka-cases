---
/*
 * Главная страница — СЕМАНТИЧЕСКИЙ КАРКАС (этап 1).
 * Секции пока пустые: только структура, порядок, id-якоря и комментарии.
 * Наполнение контентом и подключение компонентов из src/sections — на следующих этапах.
 *
 * Порядок секций:
 *   Header → Hero → TrustBar → ProblemsSolutions → About → Services →
 *   Process → Cases → Reviews → Comparison → FAQ → FinalCTA → Footer
 *   (+ мобильный StickyBar)
 *
 * Якоря для навигации: #services, #process, #cases, #reviews, #faq, #cta
 */
import Layout from '../layouts/Layout.astro';
import Header from '../sections/Header.astro';
import Hero from '../sections/Hero.astro';
import TrustBar from '../sections/TrustBar.astro';
import StickyBar from '../components/StickyBar.astro';
import ProblemsSolutions from '../sections/ProblemsSolutions.astro';
import About from '../sections/About.astro';
import Services from '../sections/Services.astro';
import Process from '../sections/Process.astro';
import Cases from '../sections/Cases.astro';
import Reviews from '../sections/Reviews.astro';
import Comparison from '../sections/Comparison.astro';
import FAQ from '../sections/FAQ.astro';
import FinalCTA from '../sections/FinalCTA.astro';
import Footer from '../sections/Footer.astro';
---

<Layout>
  {/* ШАПКА: лого, навигация, телефон, основной CTA */}
  <Header />

  <main id="main" class="relative isolate">
    {/* Чертёжная линия: рисуется по скроллу (JS). За тёмными секциями скрыта (они
        перекрывают -z-10), сквозь светлые — видна. На мобильных скрыта. */}
    <svg
      class="pointer-events-none absolute left-1/2 top-0 -z-10 hidden h-full w-px -translate-x-1/2 opacity-[0.35] lg:block"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      <line
        data-draft-line
        x1="0.5"
        y1="0"
        x2="0.5"
        y2="100%"
        pathLength="1"
        stroke-width="1"
        vector-effect="non-scaling-stroke"
        class="stroke-brass"
      />
    </svg>

    {/* ПЕРВЫЙ ЭКРАН: оффер, ключевое обещание, форма заявки */}
    <Hero />

    {/* ПОЛОСА ДОВЕРИЯ: площадки и банки под Hero */}
    <TrustBar />

    {/* БОЛИ И РЕШЕНИЯ: проблемы клиента ↔ как риелтор их закрывает */}
    <ProblemsSolutions />

    {/* О РИЕЛТОРЕ: опыт, экспертиза, позиционирование, фото */}
    <About />

    {/* УСЛУГИ (якорь #services) */}
    <Services />

    {/* ПРОЦЕСС РАБОТЫ (якорь #process) */}
    <Process />

    {/* КЕЙСЫ / ПОРТФОЛИО СДЕЛОК (якорь #cases) */}
    <Cases />

    {/* ОТЗЫВЫ КЛИЕНТОВ (якорь #reviews) */}
    <Reviews />

    {/* СРАВНЕНИЕ: «самостоятельно» ↔ «с риелтором» */}
    <Comparison />

    {/* ЧАСТЫЕ ВОПРОСЫ (якорь #faq) */}
    <FAQ />

    {/* ФИНАЛЬНЫЙ ПРИЗЫВ + ФОРМА ЗАЯВКИ (якорь #cta) */}
    <FinalCTA />
  </main>

  {/* ПОДВАЛ: контакты, реквизиты, мессенджеры, политика конфиденциальности */}
  <Footer />

  {/* МОБИЛЬНАЯ ЛИПКАЯ ПАНЕЛЬ: быстрый звонок/заявка, скрыта на десктопе */}
  <StickyBar />
</Layout>
