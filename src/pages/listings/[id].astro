---
/**
 * /listings/<id>/ — детальная страница объекта недвижимости (статическая генерация из
 * listings.ts по id). Углубление из карточки на /listings/. Вверху стрелка «К объявлениям»
 * (history.back(), если пришли с этого же сайта, иначе {base}listings/). Фото пока плейсхолдер
 * под будущую галерею (см. TODO). Форма заявки — LeadForm с уникальным idPrefix listing-<id>;
 * каким объектом интересуются, видно в заявке по URL страницы (payload.page). Контакты — из site.ts.
 */
import Layout from '../../layouts/Layout.astro';
import LeadForm from '../../components/LeadForm.astro';
import AgentContacts from '../../components/AgentContacts.astro';
import { listings, listingCategories } from '../../data/listings';
import { site } from '../../data/site';
import { ArrowLeft, Building2, MapPin } from 'lucide-static';

export function getStaticPaths() {
  return listings.map((listing) => ({
    params: { id: listing.id },
    props: { listing },
  }));
}

const { listing } = Astro.props;
const base = import.meta.env.BASE_URL;
const categoryTitle =
  listingCategories.find((c) => c.id === listing.category)?.title ?? listing.category;
// Яндекс сам находит объект по адресу — координаты не вшиваем
const mapHref = `https://yandex.ru/maps/?text=${encodeURIComponent(listing.address)}`;
// Полный список характеристик: площадь + метро (если есть) + все params, без обрезки.
// Площадь уже показана явно — убираем её дубль из params (в загородке/участках м²/сотки повторяются).
const characteristics = [
  `Площадь: ${listing.area}`,
  ...(listing.metro ? [`Метро: ${listing.metro}`] : []),
  ...listing.params.filter((param) => param !== listing.area),
];
const pageTitle = `${listing.title}, ${listing.price} — Первый город`;
const pageDescription = `${listing.title}. Цена ${listing.price}, площадь ${listing.area}, адрес: ${listing.address}.`;
---

<Layout title={pageTitle} description={pageDescription}>
  <main id="main">
    {/* Стрелка «К объявлениям» — вернёт на /listings/ (позиция скролла/фильтр, если пришли оттуда) */}
    <div class="wrap py-6">
      <a
        href={`${base}listings/`}
        data-back-link
        class="inline-flex w-fit items-center gap-2 text-sm font-medium text-brass transition-colors hover:underline [&>svg]:h-4 [&>svg]:w-4"
      >
        <span set:html={ArrowLeft} aria-hidden="true" />К объявлениям
      </a>
    </div>

    <div class="wrap flex flex-col gap-10 pb-24 lg:pb-32">
      {/* Фото объекта — крупный плейсхолдер. TODO: заменить на реальную галерею/фото */}
      <div class="relative aspect-[16/9] overflow-hidden rounded-xl border border-brass/30 bg-[linear-gradient(160deg,var(--color-pine),var(--color-ink))]">
        <div class="absolute inset-0 grid place-items-center text-paper opacity-20 [&>svg]:h-24 [&>svg]:w-24">
          <span set:html={Building2} aria-hidden="true" />
        </div>
      </div>

      {/* Заголовок: категория, название, цена */}
      <header class="flex flex-col gap-3">
        <p class="eyebrow text-brass">{categoryTitle}</p>
        <h1>{listing.title}</h1>
        <p class="stat-num text-[40px] leading-none text-brass sm:text-[48px]">{listing.price}</p>
      </header>

      {/* Адрес + кнопка «на карте» */}
      <div class="flex flex-col gap-4">
        <p class="flex items-start gap-2 text-ink [&>svg]:mt-0.5 [&>svg]:h-5 [&>svg]:w-5 [&>svg]:shrink-0 [&>svg]:text-brass">
          <span set:html={MapPin} aria-hidden="true" />{listing.address}
        </p>
        <a
          href={mapHref}
          target="_blank"
          rel="noopener"
          class="inline-flex min-h-[44px] w-fit items-center gap-2 rounded-card border border-stone px-4 text-sm font-medium text-ink transition-colors hover:border-brass hover:text-brass [&>svg]:h-4 [&>svg]:w-4"
        >
          <span set:html={MapPin} aria-hidden="true" />Показать на карте
        </a>
      </div>

      {/* Характеристики — полный список (2 колонки на десктопе), без обрезки */}
      <div class="flex flex-col gap-4 border-t border-stone pt-8">
        <h2 class="text-xl">Характеристики</h2>
        <ul class="grid gap-x-10 gap-y-3 sm:grid-cols-2">
          {
            characteristics.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brass" aria-hidden="true" />
                <span class="text-ink">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Полное описание — без line-clamp, ширина ≤65ch */}
      <div class="flex flex-col gap-3 border-t border-stone pt-8">
        <h2 class="text-xl">Описание</h2>
        <p class="measure text-muted">{listing.description}</p>
      </div>

      {/* CTA — заявка именно по этому объекту (объект виден в заявке по URL страницы) */}
      <div class="rounded-xl border border-brass/40 bg-paper p-6 shadow-sm lg:p-8">
        <p class="font-sans text-[19px] font-semibold text-ink">Заинтересовал объект?</p>
        <p class="mb-5 mt-1 text-sm text-muted">
          Оставьте заявку — расскажу подробности и организую показ.
        </p>
        <LeadForm variant="light" submitText="Оставить заявку" idPrefix={`listing-${listing.id}`} />
      </div>

      {/* Контакты агентства — телефон и мессенджеры из site.ts */}
      <AgentContacts telegram={{ handle: site.telegram, href: site.telegramHref }} showMax />
    </div>
  </main>

  <script>
    // Стрелка «К объявлениям»: если пришли с этого же сайта — history.back() (браузер
    // вернёт позицию скролла и активный фильтр на /listings/); иначе href на {base}listings/.
    const backLink = document.querySelector('[data-back-link]');
    if (backLink instanceof HTMLAnchorElement) {
      backLink.addEventListener('click', (event) => {
        if (
          document.referrer &&
          document.referrer.includes(window.location.host) &&
          window.history.length > 1
        ) {
          event.preventDefault();
          window.history.back();
        }
      });
    }
  </script>
</Layout>
