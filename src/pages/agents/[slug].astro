---
/**
 * /agents/<slug>/ — страница профиля агента (генерируется статически из agents.ts).
 * Вёрстка как в прежней About: портрет (aspect-4/5) слева и текст справа на десктопе
 * (h1 с именем, роль, теги специализации, 3 абзаца био, регалии с галочками brass,
 * SVG-факсимиле подписи), кнопка «Обсудить мою ситуацию» → главная к форме (#cta).
 * Вверху — стрелка «К агентам»: если пользователь пришёл с этого же сайта, делаем
 * history.back() (браузер вернёт позицию скролла на секции агентов), иначе переходим
 * на /#agents. Все ссылки — с учётом BASE_URL (подпапка GitHub Pages).
 */
import { Picture } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import { agents, agentPage } from '../../data/agents';
import AgentServices from '../../components/AgentServices.astro';
import AgentCases from '../../components/AgentCases.astro';
import AgentReviews from '../../components/AgentReviews.astro';
import AgentCertificates from '../../components/AgentCertificates.astro';
import AgentHelp from '../../components/AgentHelp.astro';
import AgentContacts from '../../components/AgentContacts.astro';
import { User, Check, ArrowLeft } from 'lucide-static';
import dariaPhoto from '../../assets/daria.jpg';

export function getStaticPaths() {
  return agents.map((agent) => ({
    params: { slug: agent.slug },
    props: { agent },
  }));
}

const { agent } = Astro.props;
const base = import.meta.env.BASE_URL;
const pageTitle = `${agent.name} — ${agent.role} · Первый город`;
const pageDescription = agent.summary;
---

<Layout title={pageTitle} description={pageDescription}>
  <main id="main" class="section-y">
    <div class="wrap flex flex-col gap-10">
      {/* Стрелка «назад» — восстанавливает позицию скролла на секции агентов */}
      <a
        href={`${base}#agents`}
        data-back-link
        class="inline-flex w-fit items-center gap-2 text-sm font-medium text-brass transition-colors hover:underline [&>svg]:h-4 [&>svg]:w-4"
      >
        <span set:html={ArrowLeft} aria-hidden="true" />{agentPage.backLabel}
      </a>

      <div class="grid items-center gap-10 lg:grid-cols-12 lg:gap-14">
        {/* Текст: на мобильном первый, на десктопе справа */}
        <div class="order-1 flex flex-col gap-6 lg:order-2 lg:col-span-7">
          <div class="flex flex-col gap-3">
            <p class="eyebrow">{agent.role}</p>
            <h1>{agent.name}</h1>
            <ul class="flex flex-wrap gap-2">
              {
                agent.specialization.map((tag) => (
                  <li class="rounded-card border border-stone px-3 py-1 text-sm text-muted">{tag}</li>
                ))
              }
            </ul>
          </div>

          <div class="flex flex-col gap-4">
            {agent.bio.map((paragraph) => <p class="measure text-muted">{paragraph}</p>)}
          </div>

          <ul class="flex flex-col gap-3 border-t border-stone pt-5">
            {
              agent.credentials.map((credential) => (
                <li class="flex items-start gap-3">
                  <span
                    class="mt-0.5 inline-flex shrink-0 text-brass [&>svg]:h-5 [&>svg]:w-5"
                    set:html={Check}
                    aria-hidden="true"
                  />
                  <span class="text-ink">{credential}</span>
                </li>
              ))
            }
          </ul>

          {/* Факсимиле подписи — плейсхолдер */}
          <div class="flex flex-col gap-2">
            {/* TODO: заменить на реальную подпись агента */}
            <svg class="h-14 w-auto fill-none stroke-brass opacity-80" viewBox="0 0 240 70" aria-hidden="true">
              <path
                d="M4 48 C 14 18 26 16 24 42 C 22 64 40 62 44 36 C 47 14 60 14 58 42 C 70 32 86 34 92 46 C 80 50 98 54 108 40 C 118 28 132 32 126 50 C 150 30 188 30 232 46"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                vector-effect="non-scaling-stroke"
              />
            </svg>
            <span class="text-sm text-muted">{agent.name} · {agent.role}</span>
          </div>
        </div>

        {/* Фото: на мобильном второй, на десктопе слева. Дарья — реальное фото
            (astro:assets, eager/LCP этой страницы), Дмитрий — плейсхолдер */}
        <div class="order-2 lg:order-1 lg:col-span-5">
          <div class="relative mx-auto aspect-[4/5] w-full max-w-sm overflow-hidden rounded-xl border border-brass/40 bg-[linear-gradient(160deg,var(--color-pine),var(--color-ink))] lg:mx-0">
            {
              agent.slug === 'darya-salnikova' && (
                <Picture
                  src={dariaPhoto}
                  formats={['avif', 'webp']}
                  width={768}
                  quality={82}
                  alt={`${agent.name}, риелтор`}
                  loading="eager"
                  fetchpriority="high"
                  class="absolute inset-0 h-full w-full object-cover"
                />
              )
            }
            {/* внутренняя рамка brass — поверх фото/градиента */}
            <div class="absolute inset-3 rounded-lg border border-brass/30" />
            {
              agent.slug !== 'darya-salnikova' && (
                <div class="absolute inset-0 grid place-items-center text-paper opacity-20 [&>svg]:h-24 [&>svg]:w-24">
                  <span set:html={User} aria-hidden="true" />
                </div>
              )
            }
            {/* TODO: фото Дмитрия — заменить плейсхолдер, когда будет фото */}
          </div>
        </div>
      </div>

      {/* Чем могу помочь — блок компетенций под био (у Дарьи заполнен, у Дмитрия пусто) */}
      <AgentHelp help={agent.help} />

      {/* Услуги агента — переехали с главной; у каждого агента свой набор (agents.ts) */}
      <AgentServices services={agent.services} />

      {/* Кейсы агента — переехали с главной; у Дарьи её сделки, у Дмитрия пока пусто */}
      <AgentCases cases={agent.cases} />

      {/* Отзывы агента — переехали с главной; у Дарьи реальные, у Дмитрия пока пусто */}
      <AgentReviews reviews={agent.reviews} />

      {/* Сертификаты и дипломы — самый низ профиля; галерея с лайтбоксом (у Дарьи, у Дмитрия пусто) */}
      <AgentCertificates certificates={agent.certificates} />

      {/* Контакты — общие контакты компании (site.ts); показываем у основного контакта (Дарьи) */}
      {agent.slug === 'darya-salnikova' && <AgentContacts />}

      <div>
        <Button variant="ghost" href={`${base}#cta`}>{agentPage.ctaLabel}</Button>
      </div>
    </div>
  </main>

  <script>
    // Стрелка «К агентам»: если пришли с этого же сайта — history.back() (браузер
    // вернёт позицию скролла на секции агентов); иначе срабатывает href на /#agents.
    const backLink = document.querySelector('[data-back-link]');
    if (backLink instanceof HTMLAnchorElement) {
      backLink.addEventListener('click', (event) => {
        if (
          document.referrer &&
          document.referrer.includes(window.location.host) &&
          window.history.length > 1
        ) {
          event.preventDefault();
          window.history.back();
        }
      });
    }
  </script>
</Layout>
