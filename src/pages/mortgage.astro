---
/**
 * /mortgage/ — отдельная страница «Ипотека»: калькулятор, форма заявки и банки.
 * Переиспользует секцию Mortgage.astro. Вверху — стрелка «На главную»:
 * если реферер с этого же сайта → history.back() (вернётся позиция скролла),
 * иначе переход на / (с учётом BASE_URL — подпапка GitHub Pages).
 * Форма (LeadForm formType='mortgage') и калькулятор — те же компоненты, их скрипты
 * бандлит Astro; PUBLIC_LEAD_ENDPOINT инлайнится при сборке.
 */
import Layout from '../layouts/Layout.astro';
import Mortgage from '../sections/Mortgage.astro';
import { mortgageHeading } from '../data/mortgage';
import { ArrowLeft } from 'lucide-static';

const base = import.meta.env.BASE_URL;
const pageTitle = 'Ипотека: калькулятор и заявка — Первый город';
const pageDescription = mortgageHeading.subtitle;
---

<Layout title={pageTitle} description={pageDescription}>
  <main id="main">
    {/* Стрелка «На главную» — восстанавливает позицию скролла, если пришли с сайта */}
    <div class="wrap py-6">
      <a
        href={base}
        data-back-link
        class="inline-flex w-fit items-center gap-2 text-sm font-medium text-brass transition-colors hover:underline [&>svg]:h-4 [&>svg]:w-4"
      >
        <span set:html={ArrowLeft} aria-hidden="true" />На главную
      </a>
    </div>

    <Mortgage />
  </main>

  <script>
    // Стрелка «На главную»: если пришли с этого же сайта — history.back()
    // (браузер вернёт позицию скролла); иначе срабатывает href на / (с BASE_URL).
    const backLink = document.querySelector('[data-back-link]');
    if (backLink instanceof HTMLAnchorElement) {
      backLink.addEventListener('click', (event) => {
        if (
          document.referrer &&
          document.referrer.includes(window.location.host) &&
          window.history.length > 1
        ) {
          event.preventDefault();
          window.history.back();
        }
      });
    }
  </script>
</Layout>
