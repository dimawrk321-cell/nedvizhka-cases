---
/**
 * /listings/ — «Объявления»: страница-перекрёсток. Каталог объектов на сайте больше не
 * ведём — все актуальные предложения агентства публикуются на Авито и Циан. Здесь две
 * крупные карточки-ссылки на площадки. Логотипы/бренд-цвета площадок не используем
 * (товарные знаки) — только текст в нашей палитре (brass/ink/stone/paper).
 */
import Layout from '../layouts/Layout.astro';
import BackLink from '../components/BackLink.astro';
import Button from '../components/Button.astro';
import { Building2, ArrowUpRight } from 'lucide-static';

const base = import.meta.env.BASE_URL;
const pageTitle = 'Объявления — Первый город';
const pageDescription =
  'Объекты агентства «Первый город» — квартиры, дома и участки — опубликованы на Авито и Циан. Актуальные предложения с фото и ценами.';

const platforms = [
  {
    name: 'Авито',
    caption: 'Все объекты агентства',
    // context-параметр в исходной ссылке временный — не включаем
    href: 'https://www.avito.ru/brands/i194417548/items/all/kvartiry',
  },
  {
    name: 'Циан',
    caption: 'Актуальные предложения',
    href: 'https://www.cian.ru/company/66328155',
  },
  {
    name: 'Домклик',
    caption: 'Объекты агентства',
    href: 'https://agencies.domclick.ru/agency/306343',
  },
];
---

<Layout title={pageTitle} description={pageDescription}>
  <main id="main">
    {/* Кнопка «На главную» */}
    <div class="wrap py-6">
      <BackLink href={base} label="На главную" />
    </div>

    <div class="wrap flex flex-col gap-12 pb-24 pt-2 lg:pb-32">
      {/* Заголовок страницы */}
      <header class="flex flex-col gap-4">
        <p class="eyebrow text-brass">Объявления</p>
        <h2>Наши объекты на площадках</h2>
        <p class="text-lg text-muted">
          Все актуальные предложения агентства опубликованы на Авито, Циан и Домклик. Переходите,
          чтобы посмотреть квартиры, дома и участки с фото и ценами.
        </p>
      </header>

      {/* Три крупные карточки-ссылки на площадки: по трети на десктопе/планшете, столбцом на мобильном */}
      <div class="grid gap-6 sm:grid-cols-3 sm:gap-8">
        {
          platforms.map((platform) => (
            <a
              href={platform.href}
              target="_blank"
              rel="noopener"
              class="group flex flex-col gap-8 rounded-xl border border-stone bg-paper p-8 transition duration-200 hover:-translate-y-1 hover:border-brass hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brass focus-visible:ring-offset-2 focus-visible:ring-offset-paper lg:p-10"
            >
              <div class="flex items-start justify-between">
                <span
                  class="inline-flex h-12 w-12 items-center justify-center rounded-card border border-stone text-brass transition-colors group-hover:border-brass [&>svg]:h-6 [&>svg]:w-6"
                  set:html={Building2}
                  aria-hidden="true"
                />
                <span
                  class="inline-flex text-muted transition-all duration-200 group-hover:-translate-y-1 group-hover:translate-x-1 group-hover:text-brass [&>svg]:h-6 [&>svg]:w-6"
                  set:html={ArrowUpRight}
                  aria-hidden="true"
                />
              </div>
              <div class="flex flex-col gap-1">
                <span class="font-display text-3xl leading-none text-ink lg:text-4xl">{platform.name}</span>
                <span class="text-muted">{platform.caption}</span>
              </div>
            </a>
          ))
        }
      </div>

      {/* Мягкий призыв — на случай, если на площадках не нашлось подходящего */}
      <div class="flex flex-col gap-4 border-t border-stone pt-8">
        <p class="text-muted">Не нашли подходящий вариант? Оставьте заявку — подберём под ваш запрос.</p>
        <div>
          <Button variant="ghost" href={`${base}#cta`}>Оставить заявку</Button>
        </div>
      </div>
    </div>
  </main>
</Layout>
