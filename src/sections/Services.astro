---
/**
 * Services — светлая секция. 5 услуг из services.ts.
 * Сетка 6 колонок: 3 карточки сверху (span 2) + 2 снизу (span 3) — без «висящей»
 * одинокой карточки; на sm последняя растягивается на всю ширину. У каждой услуги —
 * осмысленная lucide-иконка. Hover карточек — по общему правилу (CSS-переход).
 */
import SectionHeading from '../components/SectionHeading.astro';
import { services, servicesHeading } from '../data/services';
import { Home, Search, ArrowLeftRight, Landmark, ShieldCheck } from 'lucide-static';

// Иконки в порядке услуг: продажа, покупка, альтернатива, ипотека, сопровождение
const icons = [Home, Search, ArrowLeftRight, Landmark, ShieldCheck];
---

<section id="services" data-section="services" data-bg="light" class="section-y">
  <div class="wrap flex flex-col gap-12">
    <SectionHeading eyebrow={servicesHeading.eyebrow} title={servicesHeading.title} align="center" />

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-6">
      {
        services.map((service, i) => (
          <article
            class:list={[
              'group flex flex-col gap-4 rounded-lg border border-stone bg-paper p-6 transition duration-200 hover:-translate-y-1 hover:border-brass hover:shadow-md',
              i < 3 && 'lg:col-span-2',
              i === 3 && 'lg:col-span-3',
              i === 4 && 'sm:col-span-2 lg:col-span-3',
            ]}
          >
            <span
              class="inline-flex h-12 w-12 items-center justify-center rounded-card border border-stone text-brass transition-colors group-hover:border-brass [&>svg]:h-6 [&>svg]:w-6"
              set:html={icons[i]}
              aria-hidden="true"
            />
            <h3 class="text-lg font-semibold text-ink">{service.title}</h3>
            <p class="text-muted">{service.result}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
