---
/**
 * Comparison — светлая секция. 3 варианта × 5 критериев из comparison.ts.
 * Десктоп — настоящая <table> с th[scope]; колонка «Со мной» выделена (brass-акцент,
 * бейдж, check). Мобайл — 3 карточки-стопки (без горизонтального скролла), «Со мной»
 * первой с акцентом.
 */
import SectionHeading from '../components/SectionHeading.astro';
import { comparison, comparisonColumns, comparisonHeading } from '../data/comparison';
import { Check } from 'lucide-static';

// Для мобильных карточек: «Со мной» первой и выделена
const columns = [
  { key: 'mine' as const, label: comparisonColumns.mine, highlighted: true },
  { key: 'agency' as const, label: comparisonColumns.agency, highlighted: false },
  { key: 'diy' as const, label: comparisonColumns.diy, highlighted: false },
];
---

<section data-section="comparison" data-bg="light" class="section-y">
  <div class="wrap flex flex-col gap-12">
    <SectionHeading eyebrow={comparisonHeading.eyebrow} title={comparisonHeading.title} align="center" />

    {/* Десктоп: таблица */}
    <table class="hidden w-full border-separate border-spacing-0 lg:table">
      <caption class="sr-only">{comparisonHeading.title}</caption>
      <thead>
        <tr>
          <th scope="col" class="w-1/4 p-4"><span class="sr-only">Критерий</span></th>
          <th scope="col" class="p-4 text-left align-bottom text-base font-semibold text-muted">{comparisonColumns.diy}</th>
          <th scope="col" class="p-4 text-left align-bottom text-base font-semibold text-muted">{comparisonColumns.agency}</th>
          <th scope="col" class="rounded-t-lg border-x border-t border-brass bg-brass/5 p-4 text-left align-bottom text-base font-semibold text-ink">
            <span class="flex items-center gap-2">
              {comparisonColumns.mine}
              <span class="rounded-full bg-brass px-2 py-0.5 text-xs font-medium text-ink">{comparisonHeading.recommended}</span>
            </span>
          </th>
        </tr>
      </thead>
      <tbody>
        {
          comparison.map((row, i) => (
            <tr>
              <th scope="row" class="border-t border-stone p-4 text-left align-top text-sm font-semibold text-ink">
                {row.criterion}
              </th>
              <td class="border-t border-stone p-4 align-top text-sm text-ink">{row.diy}</td>
              <td class="border-t border-stone p-4 align-top text-sm text-ink">{row.agency}</td>
              <td
                class:list={[
                  'border-x border-brass bg-brass/5 p-4 align-top text-sm text-ink',
                  i === comparison.length - 1 && 'rounded-b-lg border-b',
                ]}
              >
                <span class="flex items-start gap-2">
                  <span class="mt-0.5 inline-flex shrink-0 text-brass [&>svg]:h-4 [&>svg]:w-4" set:html={Check} aria-hidden="true" />
                  <span>{row.mine}</span>
                </span>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>

    {/* Мобайл: карточки-стопки */}
    <div class="flex flex-col gap-5 lg:hidden">
      {
        columns.map((col) => (
          <div class:list={['rounded-lg border p-6', col.highlighted ? 'border-brass bg-brass/5' : 'border-stone bg-paper']}>
            <div class="mb-4 flex items-center gap-2">
              <h3 class="text-lg font-semibold text-ink">{col.label}</h3>
              {col.highlighted && (
                <span class="rounded-full bg-brass px-2 py-0.5 text-xs font-medium text-ink">{comparisonHeading.recommended}</span>
              )}
            </div>
            <dl class="flex flex-col gap-3">
              {comparison.map((row) => (
                <div class="flex flex-col gap-0.5 border-t border-stone/70 pt-3 first:border-0 first:pt-0">
                  <dt class="text-xs font-medium uppercase tracking-wider text-muted">{row.criterion}</dt>
                  <dd class="flex items-start gap-2 text-sm text-ink">
                    {col.highlighted && (
                      <span class="mt-0.5 inline-flex shrink-0 text-brass [&>svg]:h-4 [&>svg]:w-4" set:html={Check} aria-hidden="true" />
                    )}
                    <span>{row[col.key]}</span>
                  </dd>
                </div>
              ))}
            </dl>
          </div>
        ))
      }
    </div>
  </div>
</section>
